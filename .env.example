# Schema for the gated live integration test (npm run test:integration).
#
# Copy to .env and fill in the values. .env is gitignored; this example is the
# committed, secret-free reference. The same variables back the CI integration
# job (provided there as GitHub Actions secrets, not a file).

# The S3-compatible API endpoint, e.g. https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# SigV4 signing region (R2 accepts "auto").
R2_REGION=auto

# Bucket name.
R2_BUCKET=

# "path" or "virtual-hosted".
R2_ADDRESSING=path

# Credentials.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Throwaway key prefix the live test confines itself to and cleans up.
R2_TEST_PREFIX=linked-attachments-livetest/
