{
	"name": "linked-attachments",
	"version": "2.2.0",
	"description": "Offload large, cold files to your own S3-compatible bucket and keep a resolvable pointer note in your vault.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint . --max-warnings 0 && node scripts/check-submission.mjs",
		"test": "jest",
		"test:integration": "node --env-file-if-exists=.env node_modules/jest/bin/jest.js --config jest.integration.config.cjs --runInBand",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [],
	"author": "Charles Kelsoe (ckelsoe)",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/jest": "^30.0.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.0.7",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.2",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"fast-check": "^4.8.0",
		"globals": "^17.1.0",
		"jest": "^30.2.0",
		"jiti": "^2.6.1",
		"obsidian": "^1.13.0",
		"ts-jest": "^29.4.6",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.35.1"
	},
	"overrides": {
		"handlebars": "^4.7.9",
		"picomatch": "^2.3.2",
		"flatted": "^3.4.0",
		"ajv": "^6.14.0",
		"brace-expansion@1": "^1.1.13",
		"brace-expansion@2": "^2.0.3",
		"js-yaml": "^4.2.0",
		"@babel/core": "^7.29.6"
	},
	"dependencies": {
		"js-yaml": "^4.2.0"
	}
}
